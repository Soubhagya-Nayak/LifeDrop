# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=024022
DB_NAME=lifedrop

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=lifedrop-local-dev-secret-change-in-production

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# ─── Firebase Cloud Messaging (optional – push notifications) ─────────────────
# Leave blank to disable push notifications (in-app DB notifications still work)
# Get these from your Firebase project → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the full private key (including -----BEGIN/END PRIVATE KEY-----).
# Replace real newlines with \n so it fits on one line.
FIREBASE_PRIVATE_KEY=
